{
  "title": "shard-listener",
  "uid": "shard-listener",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["bitcoin", "bsv", "networking", "multicast-lab", "shard-listener", "listener"],
  "timezone": "",
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(bsl_frames_received_total, instance)", "refId": "a" },
        "includeAll": true,
        "multi": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Ingress",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Frames received (rate by instance, version)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance, version) (rate(bsl_frames_received_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} v{{version}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Frames received (rate by worker)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 1, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance, worker) (rate(bsl_frames_received_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} w{{worker}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Filtering",
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Frames dropped (rate by reason)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance, reason) (rate(bsl_frames_dropped_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} {{reason}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Dropped total (last 15m, by reason)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (reason) (increase(bsl_frames_dropped_total{instance=~\"$instance\"}[15m]))",
          "legendFormat": "{{reason}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "piechart",
      "title": "Drop distribution by reason",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (reason) (increase(bsl_frames_dropped_total{instance=~\"$instance\"}[15m]))",
          "legendFormat": "{{reason}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "pieType": "pie"
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Drop % of ingress",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(bsl_frames_dropped_total{instance=~\"$instance\"}[1m])) / sum(rate(bsl_frames_received_total{instance=~\"$instance\"}[1m])) * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Egress",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Frames forwarded (rate by proto)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 27, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance, proto) (rate(bsl_frames_forwarded_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} {{proto}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Egress errors (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 27, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(bsl_egress_errors_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Forward efficiency %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(bsl_frames_forwarded_total{instance=~\"$instance\"}[1m])) / sum(rate(bsl_frames_received_total{instance=~\"$instance\"}[1m])) * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "NACK / gap recovery",
      "gridPos": { "x": 0, "y": 43, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Gaps detected vs suppressed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 44, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (instance) (rate(bsl_gaps_detected_total{instance=~\"$instance\"}[1m]))", "legendFormat": "{{instance}} detected" },
        { "expr": "sum by (instance) (rate(bsl_gaps_suppressed_total{instance=~\"$instance\"}[1m]))", "legendFormat": "{{instance}} suppressed" }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "NACK dispatched / unrecovered",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 44, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (instance) (rate(bsl_nacks_dispatched_total{instance=~\"$instance\"}[1m]))",  "legendFormat": "{{instance}} dispatched" },
        { "expr": "sum by (instance) (rate(bsl_nacks_unrecovered_total{instance=~\"$instance\"}[1m]))", "legendFormat": "{{instance}} unrecovered" }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "Gap recovery rate %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 52, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(bsl_gaps_suppressed_total{instance=~\"$instance\"}[1m])) / sum(rate(bsl_gaps_detected_total{instance=~\"$instance\"}[1m])) * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0
        }
      }
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "Unrecovered gap %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 52, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(bsl_nacks_unrecovered_total{instance=~\"$instance\"}[1m])) / sum(rate(bsl_gaps_detected_total{instance=~\"$instance\"}[1m])) * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 40,
      "type": "row",
      "title": "Runtime",
      "gridPos": { "x": 0, "y": 60, "w": 24, "h": 1 }
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Heap memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 61, "w": 12, "h": 8 },
      "targets": [
        { "expr": "go_memstats_heap_inuse_bytes{job=\"shard-listener\", instance=~\"$instance\"}", "legendFormat": "{{instance}} heap in-use" },
        { "expr": "go_memstats_heap_alloc_bytes{job=\"shard-listener\", instance=~\"$instance\"}", "legendFormat": "{{instance}} heap alloc" },
        { "expr": "go_memstats_heap_sys_bytes{job=\"shard-listener\", instance=~\"$instance\"}", "legendFormat": "{{instance}} heap sys" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Process memory (RSS / VSZ)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 61, "w": 12, "h": 8 },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"shard-listener\", instance=~\"$instance\"}", "legendFormat": "{{instance}} RSS" },
        { "expr": "process_virtual_memory_bytes{job=\"shard-listener\", instance=~\"$instance\"}", "legendFormat": "{{instance}} VSZ" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "Goroutines & threads",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 69, "w": 12, "h": 8 },
      "targets": [
        { "expr": "go_goroutines{job=\"shard-listener\", instance=~\"$instance\"}", "legendFormat": "{{instance}} goroutines" },
        { "expr": "go_threads{job=\"shard-listener\", instance=~\"$instance\"}", "legendFormat": "{{instance}} OS threads" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 44,
      "type": "timeseries",
      "title": "GC pause duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 69, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(go_gc_duration_seconds_bucket{job=\"shard-listener\", instance=~\"$instance\"}[5m]))", "legendFormat": "{{instance}} p99" },
        { "expr": "histogram_quantile(0.50, rate(go_gc_duration_seconds_bucket{job=\"shard-listener\", instance=~\"$instance\"}[5m]))", "legendFormat": "{{instance}} p50" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 45,
      "type": "timeseries",
      "title": "CPU usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 77, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total{job=\"shard-listener\", instance=~\"$instance\"}[1m])", "legendFormat": "{{instance}} CPU cores" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 46,
      "type": "stat",
      "title": "Uptime",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 77, "w": 6, "h": 8 },
      "targets": [
        { "expr": "bsl_uptime_seconds{job=\"shard-listener\", instance=~\"$instance\"}", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "dtdurations" } }
    },
    {
      "id": 47,
      "type": "stat",
      "title": "Active workers",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 77, "w": 6, "h": 8 },
      "targets": [
        { "expr": "count by (instance) (bsl_frames_received_total{instance=~\"$instance\"})", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 50,
      "type": "row",
      "title": "Readiness",
      "gridPos": { "x": 0, "y": 85, "w": 24, "h": 1 }
    },
    {
      "id": 51,
      "type": "stat",
      "title": "Target up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 86, "w": 24, "h": 4 },
      "targets": [
        { "expr": "up{job=\"shard-listener\", instance=~\"$instance\"}", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 60,
      "type": "row",
      "title": "Subtree Group Announce (BRC-127)",
      "gridPos": { "x": 0, "y": 91, "w": 24, "h": 1 }
    },
    {
      "id": 61,
      "type": "timeseries",
      "title": "Announces received (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 92, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(bsl_subtree_announces_received_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 62,
      "type": "timeseries",
      "title": "Announces rejected (rate by reason)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 92, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance, reason) (rate(bsl_subtree_announces_rejected_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}} {{reason}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 63,
      "type": "timeseries",
      "title": "Registry live entries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 100, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "bsl_subtree_group_entries{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 64,
      "type": "timeseries",
      "title": "Registry evictions (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 100, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(bsl_subtree_group_evictions_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 70,
      "type": "row",
      "title": "Beacon Discovery",
      "gridPos": { "x": 0, "y": 109, "w": 24, "h": 1 }
    },
    {
      "id": 71,
      "type": "timeseries",
      "title": "ADVERT beacons received (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 110, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(bsl_beacon_adverts_received_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 72,
      "type": "stat",
      "title": "Beacon registry endpoints",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 110, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "bsl_beacon_registry_endpoints{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 80,
      "type": "row",
      "title": "Multicast Egress Errors",
      "gridPos": { "x": 0, "y": 119, "w": 24, "h": 1 }
    },
    {
      "id": 81,
      "type": "timeseries",
      "title": "MC egress errors (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 120, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(bsl_mc_egress_errors_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 90,
      "type": "row",
      "title": "Block Header Egress (SPV)",
      "gridPos": { "x": 0, "y": 128, "w": 24, "h": 1 }
    },
    {
      "id": 91,
      "type": "timeseries",
      "title": "Headers forwarded (rate by instance)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 129, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(bsl_header_forwarded_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" } }
    },
    {
      "id": 92,
      "type": "stat",
      "title": "Headers forwarded (last 15m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 129, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (increase(bsl_header_forwarded_total{instance=~\"$instance\"}[15m]))",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 93,
      "type": "timeseries",
      "title": "Header egress errors (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 137, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (instance) (rate(bsl_header_egress_errors_total{instance=~\"$instance\"}[1m]))",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "pps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 94,
      "type": "timeseries",
      "title": "Header egress success rate %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 137, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(bsl_header_forwarded_total{instance=~\"$instance\"}[1m])) / (sum(rate(bsl_header_forwarded_total{instance=~\"$instance\"}[1m])) + sum(rate(bsl_header_egress_errors_total{instance=~\"$instance\"}[1m]))) * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    }
  ]
}
