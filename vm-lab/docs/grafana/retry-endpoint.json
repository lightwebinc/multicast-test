{
  "title": "retry-endpoint",
  "uid": "retry-endpoint",
  "schemaVersion": 39,
  "tags": ["bitcoin", "bsv", "networking", "multicast-lab", "retry-endpoint"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": {"from": "now-15m", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": {"query": "label_values(bre_frames_received_total, instance)", "refId": "a"},
        "includeAll": true,
        "multi": true,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row", "title": "Ingress (multicast frame cache)",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "id": 1, "collapsed": false
    },
    {
      "type": "timeseries", "title": "Frames received (rate)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 1}, "id": 2,
      "targets": [{"expr": "sum by (instance) (rate(bre_frames_received_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}}"}],
      "fieldConfig": {"defaults": {"unit": "fps"}, "overrides": []}
    },
    {
      "type": "timeseries", "title": "Frames cached (rate)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1}, "id": 3,
      "targets": [{"expr": "sum by (instance) (rate(bre_frames_cached_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}}"}],
      "fieldConfig": {"defaults": {"unit": "fps"}, "overrides": []}
    },
    {
      "type": "timeseries", "title": "Frames dropped (rate by reason)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1}, "id": 4,
      "targets": [{"expr": "sum by (instance, reason) (rate(bre_frames_dropped_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}} {{reason}}"}],
      "fieldConfig": {"defaults": {"unit": "fps"}, "overrides": []}
    },
    {
      "type": "row", "title": "Cache",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9}, "id": 10, "collapsed": false
    },
    {
      "type": "timeseries", "title": "Cache size (entries)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 10}, "id": 11,
      "targets": [{"expr": "sum by (instance) (bre_cache_size{instance=~\"$instance\"})", "refId": "A", "legendFormat": "{{instance}}"}]
    },
    {
      "type": "timeseries", "title": "Cache hit / miss (rate)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 10}, "id": 12,
      "targets": [
        {"expr": "sum by (instance) (rate(bre_cache_hits_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}} hits"},
        {"expr": "sum by (instance) (rate(bre_cache_misses_total{instance=~\"$instance\"}[1m]))", "refId": "B", "legendFormat": "{{instance}} miss"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "stat", "title": "Cache hit ratio (last 15m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 10}, "id": 13,
      "targets": [{"expr": "sum(increase(bre_cache_hits_total{instance=~\"$instance\"}[15m])) / clamp_min(sum(increase(bre_cache_hits_total{instance=~\"$instance\"}[15m])) + sum(increase(bre_cache_misses_total{instance=~\"$instance\"}[15m])), 1)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.9}]}}, "overrides": []}
    },
    {
      "type": "row", "title": "NACK / Retransmit",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18}, "id": 20, "collapsed": false
    },
    {
      "type": "timeseries", "title": "NACK requests received (rate)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 19}, "id": 21,
      "targets": [{"expr": "sum by (instance) (rate(bre_nack_requests_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "timeseries", "title": "Retransmissions (rate)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 19}, "id": 22,
      "targets": [
        {"expr": "sum by (instance) (rate(bre_retransmits_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}} sent"},
        {"expr": "sum by (instance) (rate(bre_retransmit_dedup_total{instance=~\"$instance\"}[1m]))", "refId": "B", "legendFormat": "{{instance}} dedup-suppressed"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "stat", "title": "NACK → retransmit ratio (last 15m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 19}, "id": 23,
      "targets": [{"expr": "sum(increase(bre_retransmits_total{instance=~\"$instance\"}[15m])) / clamp_min(sum(increase(bre_nack_requests_total{instance=~\"$instance\"}[15m])), 1)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1.5, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.9}]}}, "overrides": []}
    },
    {
      "type": "row", "title": "Rate limiting & errors",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27}, "id": 30, "collapsed": false
    },
    {
      "type": "timeseries", "title": "Rate-limit drops (rate by level)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28}, "id": 31,
      "targets": [{"expr": "sum by (instance, level) (rate(bre_rate_limit_drops_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}} {{level}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "timeseries", "title": "Cache backend errors (rate)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28}, "id": 32,
      "targets": [{"expr": "sum by (instance) (rate(bre_cache_errors_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "row", "title": "Process",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36}, "id": 40, "collapsed": false
    },
    {
      "type": "timeseries", "title": "Goroutines",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 37}, "id": 41,
      "targets": [{"expr": "go_goroutines{job=\"retry-endpoint\", instance=~\"$instance\"}", "refId": "A", "legendFormat": "{{instance}}"}]
    },
    {
      "type": "timeseries", "title": "Resident memory (RSS)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 37}, "id": 42,
      "targets": [{"expr": "process_resident_memory_bytes{job=\"retry-endpoint\", instance=~\"$instance\"}", "refId": "A", "legendFormat": "{{instance}}"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}
    },
    {
      "type": "row", "title": "NACK Responses",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 46}, "id": 50, "collapsed": false
    },
    {
      "type": "timeseries", "title": "Responses sent (rate by type)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 47}, "id": 51,
      "targets": [{"expr": "sum by (instance, type) (rate(bre_responses_sent_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}} {{type}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "timeseries", "title": "Response send errors (rate)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 47}, "id": 52,
      "targets": [{"expr": "sum by (instance) (rate(bre_response_send_errors_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "type": "row", "title": "Beacon",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 56}, "id": 60, "collapsed": false
    },
    {
      "type": "timeseries", "title": "ADVERT beacons sent (rate)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 57}, "id": 61,
      "targets": [{"expr": "sum by (instance) (rate(bre_beacon_adverts_sent_total{instance=~\"$instance\"}[1m]))", "refId": "A", "legendFormat": "{{instance}}"}],
      "fieldConfig": {"defaults": {"unit": "pps"}, "overrides": []}
    }
  ]
}
